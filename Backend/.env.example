# GCP Project Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_BUCKET_NAME=your-gcs-bucket-name
PUBSUB_TOPIC=your-pubsub-topic-name
FIRESTORE_DATABASE=(default)

# Service Account — uses ADC, no key files needed
# Run: gcloud auth application-default login
GCP_SERVICE_ACCOUNT_EMAIL=your-sa-name@your-project-id.iam.gserviceaccount.com

# Video Upload Constraints
MAX_VIDEO_SIZE_MB=500
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/avi